# Backend Environment Variables

# LiteLLM (V2 AI summaries)
LITELLM_BASE_URL=http://litellm.cslui.com/v1
LITELLM_API_KEY=your-litellm-api-key
LITELLM_MODEL=claude-sonnet-4-6

# News API (Marketaux — 100 req/day free, no CC)
MARKETAUX_API_KEY=your-marketaux-token

# Legacy — no longer used
# FINNHUB_API_KEY=

# Auth
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./stock_tracker.db
# PostgreSQL (V2): DATABASE_URL=postgresql://user:pass@localhost:5432/stock_tracker

# Redis
REDIS_URL=redis://localhost:6380/0

# Email Alerts
SENDGRID_API_KEY=your-sendgrid-key
ALERT_FROM_EMAIL=alerts@yourdomain.com

# Push Notifications (Ntfy.sh)
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=your-topic-name

# Environment
ENV=development
PORT=4003
