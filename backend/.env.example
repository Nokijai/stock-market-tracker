# Backend Environment Variables

# LLM (yuanyuaicloud.cn — OpenAI-compatible, glm-5.2)
LITELLM_BASE_URL=https://yuanyuaicloud.cn/v1
LITELLM_API_KEY=your-api-key
LITELLM_MODEL=glm-5.2

# News API (Marketaux — 100 req/day free, no CC)
MARKETAUX_API_KEY=your-marketaux-token

# Auth
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:////app/data/stock_tracker.db

# Redis
REDIS_URL=redis://localhost:6380/0

# Push Notifications (Ntfy.sh)
NTFY_TOPIC=your-topic-name

# Environment
ENV=development
PORT=4003